{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://news24h/contracts/v1/Story",
  "title": "Story",
  "description": "Output of StoryPlanner — semantic narrative beats (not scenes). beat_number is assigned by code, not Claude.",
  "type": "object",
  "required": ["beats", "total_duration"],
  "additionalProperties": false,
  "properties": {
    "beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["beat_number", "goal", "viewer_question", "information_type", "visual_priority", "emotion", "duration", "transition", "narrative_intent"],
        "additionalProperties": false,
        "properties": {
          "beat_number":      { "type": "integer", "minimum": 1 },
          "goal":             { "type": "string" },
          "viewer_question":  { "type": "string" },
          "information_type": { "type": "string", "enum": ["FACT", "PROCESS", "COMPARISON", "EMOTION", "SPECULATION", "DETAIL", "SUMMARY"] },
          "visual_priority":  { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
          "emotion":          { "type": "string" },
          "duration":         { "type": "number", "exclusiveMinimum": 0 },
          "transition":       { "type": "string" },
          "narrative_intent": { "type": "string" }
        }
      }
    },
    "total_duration": { "type": "number", "exclusiveMinimum": 0 }
  }
}
