{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://news24h/contracts/v1/ArticleContext",
  "title": "ArticleContext",
  "description": "Raw article data fed into the planning pipeline. Never modified by planners.",
  "type": "object",
  "required": ["article_id", "title", "hook", "category", "domain", "facts_json", "viral_score"],
  "additionalProperties": false,
  "properties": {
    "article_id": { "type": "string", "format": "uuid" },
    "title":      { "type": "string", "minLength": 1 },
    "hook":       { "type": "string", "description": "fb_image_text or title — proven attention hook" },
    "category":   { "type": "string" },
    "domain":     { "type": "string", "description": "e.g. 'motorcycle customization', 'NFL draft'" },
    "facts_json": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement"],
        "properties": {
          "id":        { "type": "string" },
          "statement": { "type": "string" },
          "fact_type": { "type": "string" }
        }
      }
    },
    "viral_score": { "type": "integer", "minimum": 0, "maximum": 100 }
  }
}
