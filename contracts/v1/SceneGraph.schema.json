{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://news24h/contracts/v1/SceneGraph",
  "title": "SceneGraph",
  "description": "Final compiled artifact served to Python MediaFactoryWorker. Built realtime by SceneGraphCompiler. Every required field is an invariant — no optional shortcuts.",
  "type": "object",
  "required": [
    "graph_version",
    "project_id", "article_id", "theme", "duration",
    "contract_version", "planner_version", "compiler_version", "workflow_version",
    "total_scenes", "total_shots", "total_duration_ms",
    "estimated_cost",
    "scenes",
    "narration_text"
  ],
  "additionalProperties": false,
  "properties": {
    "graph_version":    { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "project_id":       { "type": "string", "format": "uuid" },
    "article_id":       { "type": "string", "format": "uuid" },
    "theme":            { "type": "string" },
    "style":            { "type": "string" },
    "duration":         { "type": "integer" },
    "contract_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "planner_version":  { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "compiler_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "workflow_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "total_scenes":     { "type": "integer", "minimum": 1 },
    "total_shots":      { "type": "integer", "minimum": 1 },
    "total_duration_ms":{ "type": "integer", "minimum": 1 },
    "estimated_cost": {
      "type": "object",
      "required": ["flux", "kling", "kenburns", "voice", "total"],
      "additionalProperties": false,
      "properties": {
        "flux":     { "type": "number", "minimum": 0 },
        "kling":    { "type": "number", "minimum": 0 },
        "kenburns": { "type": "number", "minimum": 0 },
        "voice":    { "type": "number", "minimum": 0 },
        "total":    { "type": "number", "minimum": 0 }
      }
    },
    "narration_text": { "type": "string" },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scene_id", "scene_number", "title", "emotion", "duration", "shots"],
        "additionalProperties": false,
        "properties": {
          "scene_id":     { "type": "string" },
          "scene_number": { "type": "integer", "minimum": 1 },
          "title":        { "type": "string" },
          "emotion":      { "type": "string" },
          "duration":     { "type": "number", "exclusiveMinimum": 0 },
          "shots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "shot_id", "shot_order",
                "compiled_prompt", "hint",
                "dur", "start_ms", "end_ms", "sequence_id",
                "asset"
              ],
              "additionalProperties": false,
              "properties": {
                "shot_id":         { "type": "string" },
                "shot_order":      { "type": "integer", "minimum": 1 },
                "compiled_prompt": { "type": "string" },
                "hint":            { "type": "string" },
                "dur":             { "type": "number", "exclusiveMinimum": 0 },
                "start_ms":        { "type": "integer", "minimum": 0 },
                "end_ms":          { "type": "integer", "minimum": 1 },
                "sequence_id":     { "type": "string", "pattern": "^S\\d{2}_SH\\d{2}$" },
                "cinematic_dsl":   { "type": "object" },
                "asset": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "id":        { "type": "string" },
                    "type":      { "type": "string" },
                    "reuse":     { "type": "boolean" },
                    "variation": { "type": "string" },
                    "asset_key": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
