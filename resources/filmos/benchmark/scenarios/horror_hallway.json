{
    "schema_version": 1,
    "id": "horror_hallway",
    "suite": "motion",
    "level": "A",
    "difficulty": "hard",
    "duration_seconds": 10,

    "primary_learning_dimension": "occlusion",
    "secondary_learning_dimensions": ["motion_complexity", "lighting"],
    "stress_dimensions": ["flickering_light_occlusion", "figure_appearing_between_frames", "long_corridor_depth", "handheld_panic_motion"],

    "goal": "The audience should dread every flicker of the light, because the hallway is only empty while it is lit.",

    "facts": [
        { "id": "F1", "text": "A hospital hallway at night is lit by one failing fluorescent tube",  "category": "CONTEXT",  "visual_relevance": "HIGH",   "confidence": 0.95, "visual_hint": "long corridor under a stuttering light" },
        { "id": "F2", "text": "A nurse walks the corridor checking doors as the light stutters",     "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.92, "visual_hint": "lone figure with a small flashlight" },
        { "id": "F3", "text": "During one blackout a standing figure appears at the corridor's end", "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.94, "visual_hint": "motionless silhouette where none stood" },
        { "id": "F4", "text": "Each flicker brings the figure closer without it ever moving",        "category": "RESULT",   "visual_relevance": "HIGH",   "confidence": 0.91, "visual_hint": "silhouette nearer after every blackout" }
    ],

    "world_objects": [
        { "id": "nurse_obj",    "type": "character", "label": "Night nurse",       "attributes": { "carrying": "small flashlight" } },
        { "id": "figure_obj",   "type": "character", "label": "Standing figure",   "attributes": { "state": "motionless, unlit" } },
        { "id": "hallway_obj",  "type": "location",  "label": "Hospital hallway",  "attributes": { "length": "very long", "lighting": "one failing tube" } }
    ],

    "world_facts": {
        "time": "3 a.m.",
        "light": "single failing fluorescent, blackouts lasting a breath",
        "sound": "electrical buzz, distant monitor beeps",
        "setting": "deserted hospital ward",
        "rule": "the figure only moves during blackouts"
    },

    "characters": [
        {
            "id": "nurse",
            "label": "Night nurse",
            "world_object_ref": "nurse_obj",
            "appearance": { "outfit": "pale scrubs, lanyard, small flashlight", "build": "slight" }
        },
        {
            "id": "figure",
            "label": "Standing figure",
            "world_object_ref": "figure_obj",
            "appearance": { "outfit": "indistinct dark silhouette", "build": "tall, unnaturally still" }
        }
    ],

    "emotion_arc": {
        "nurse": [
            { "at": "baseline",   "state": "neutral", "intensity": "subtle" },
            { "at": "hook",       "state": "neutral", "intensity": "subtle",   "cause": "routine rounds, annoying flicker" },
