            { "at": "payoff",     "state": "fear",    "intensity": "intense",  "cause": "the figure closer after every blackout" }
        ]
    },

    "shots": {
        "hook": {
            "importance": "required",
            "action": "A nurse walks a long hospital corridor under a stuttering fluorescent tube, checking door handles as she goes",
            "camera": { "shot_type": "wide", "angle": "eye_level", "movement": "dolly", "lens": "normal", "focus_node": "nurse_node" },
            "ending_frame": "The light drops out for a full breath, then buzzes back on"
        },
        "escalation": {
            "importance": "required",
            "action": "The light returns and a motionless figure now stands at the far end of the corridor where nothing stood before",
            "camera": { "shot_type": "medium", "angle": "eye_level", "movement": "static", "lens": "telephoto", "focus_node": "figure_node" },
            "ending_frame": "The nurse's flashlight beam trembles on the distant silhouette"
        },
        "payoff": {
            "importance": "required",
            "action": "The light stutters through three blackouts and the figure stands closer after each one, never seen moving, until it fills the frame",
            "camera": { "shot_type": "close_up", "angle": "eye_level", "movement": "handheld", "lens": "normal", "focus_node": "figure_node" },
            "ending_frame": "The tube dies for good, leaving only the sound of the corridor breathing"
        }
