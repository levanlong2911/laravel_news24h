{
    "schema_version": 1,
    "id": "candlelit_confession",
    "suite": "emotion",
    "level": "A",
    "difficulty": "easy",
    "duration_seconds": 8,

    "primary_learning_dimension": "emotion_intensity",
    "secondary_learning_dimensions": ["reaction_shot", "lighting"],
