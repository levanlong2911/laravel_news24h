    "goal": "The audience should hold their breath through the confession and exhale with relief when her face answers before her words do.",

    "facts": [
        { "id": "F1", "text": "Two people sit across a small table lit only by a single candle",  "category": "CONTEXT",  "visual_relevance": "HIGH",   "confidence": 0.96, "visual_hint": "candle flame between two faces" },
        { "id": "F2", "text": "He turns a small ring box over in his hands beneath the table",    "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.93, "visual_hint": "thumb worrying a velvet box edge" },
        { "id": "F3", "text": "He places the open box on the table and begins to speak",          "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.94, "visual_hint": "ring catching candlelight" },
        { "id": "F4", "text": "Her eyes well up and she smiles before he finishes the question",  "category": "RESULT",   "visual_relevance": "HIGH",   "confidence": 0.91, "visual_hint": "tearful smile in warm light" }
    ],

    "world_objects": [
