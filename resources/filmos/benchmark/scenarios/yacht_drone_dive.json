{
    "schema_version": 1,
    "id": "yacht_drone_dive",
    "suite": "camera",
    "level": "A",
    "difficulty": "hard",
    "duration_seconds": 10,

    "primary_learning_dimension": "camera_movement",
    "secondary_learning_dimensions": ["camera_angle", "shot_type_choice"],
    "stress_dimensions": ["altitude_change", "scale_transition", "water_surface_detail"],

    "goal": "The audience should feel the vertigo of falling from god's-eye abstraction down to human scale, ending eye to eye with a single diver mid-leap.",

    "facts": [
        { "id": "F1", "text": "A white yacht cuts a straight wake across open turquoise water",         "category": "CONTEXT",  "visual_relevance": "HIGH",   "confidence": 0.95, "visual_hint": "white hull and wake from high altitude" },
        { "id": "F2", "text": "The camera descends from high altitude toward the moving stern",         "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.93, "visual_hint": "deck details growing rapidly" },
        { "id": "F3", "text": "A woman runs the length of the deck toward the stern",                   "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.92, "visual_hint": "figure sprinting along the rail" },
        { "id": "F4", "text": "She dives off the stern as the camera reaches eye level with the water", "category": "RESULT",   "visual_relevance": "HIGH",   "confidence": 0.90, "visual_hint": "body arcing over the wake" }
    ],

    "world_objects": [
        { "id": "yacht_obj", "type": "vehicle",   "label": "White yacht",  "attributes": { "size": "40 metres", "state": "cruising" } },
        { "id": "diver_obj", "type": "character", "label": "Diver",        "attributes": { "swimwear": "red" } },
        { "id": "sea_obj",   "type": "location",  "label": "Open sea",     "attributes": { "color": "turquoise" } }
    ],

    "world_facts": {
        "time": "midday",
        "light": "hard tropical sun",
        "sea_state": "calm with yacht wake",
        "yacht_speed": "steady cruise",
        "horizon": "empty in all directions"
    },

    "characters": [
        {
            "id": "diver",
            "label": "Diver",
            "world_object_ref": "diver_obj",
            "appearance": { "outfit": "red swimsuit", "build": "athletic" }
        }
    ],

    "emotion_arc": {
        "diver": [
            { "at": "baseline",   "state": "joy",           "intensity": "moderate" },
            { "at": "escalation", "state": "determination", "intensity": "moderate", "cause": "committing to the run before the stern" },
            { "at": "payoff",     "state": "joy",           "intensity": "intense",  "cause": "weightless instant above the water" }
        ]
    },

    "shots": {
        "hook": {
            "importance": "required",
            "action": "From directly overhead the yacht is a white arrowhead drawing a perfect wake across turquoise",
            "camera": { "shot_type": "establishing", "angle": "birds_eye", "movement": "static", "lens": "wide", "focus_node": "yacht_node" },
            "ending_frame": "A tiny figure appears at the bow and starts to run"
        },
        "escalation": {
            "importance": "required",
            "action": "The camera plunges toward the moving stern, deck details exploding into scale as the woman sprints past the rail",
            "camera": { "shot_type": "wide", "angle": "high", "movement": "dolly", "lens": "wide", "focus_node": "diver_node" },
            "ending_frame": "Her foot hits the stern edge as the camera levels off above the wake"
        },
        "payoff": {
            "importance": "required",
            "action": "She dives off the stern in a clean arc while the camera reaches eye level with the churning water",
            "camera": { "shot_type": "medium", "angle": "eye_level", "movement": "tracking", "lens": "normal", "focus_node": "diver_node" },
            "ending_frame": "Her fingertips break the surface as the yacht pulls away behind"
        }
    },

    "scene_nodes": {
        "hook": [
            { "id": "yacht_node", "type": "subject",    "label": "White yacht", "world_object_ref": "yacht_obj" },
            { "id": "sea_node",   "type": "background", "label": "Open sea",    "world_object_ref": "sea_obj" }
        ],
        "escalation": [
            { "id": "diver_node", "type": "subject",    "label": "Diver",       "world_object_ref": "diver_obj" },
            { "id": "yacht_node", "type": "background", "label": "Yacht deck",  "world_object_ref": "yacht_obj" }
        ],
        "payoff": [
            { "id": "diver_node", "type": "subject",    "label": "Diver",       "world_object_ref": "diver_obj" },
            { "id": "sea_node",   "type": "background", "label": "Wake water",  "world_object_ref": "sea_obj" }
        ]
    }
}
