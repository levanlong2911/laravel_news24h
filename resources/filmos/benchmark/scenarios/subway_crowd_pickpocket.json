{
    "schema_version": 1,
    "id": "subway_crowd_pickpocket",
    "suite": "camera",
    "level": "A",
    "difficulty": "extreme",
    "duration_seconds": 10,

    "primary_learning_dimension": "focus_control",
    "secondary_learning_dimensions": ["camera_tracking", "shot_type_choice"],
    "stress_dimensions": ["crowd_scale", "occlusion", "subject_isolation", "micro_action_legibility"],

    "goal": "The audience should spot the theft before the victim does, feeling the guilty thrill of being the only witness in a crowd of hundreds.",

    "facts": [
        { "id": "F1", "text": "Rush-hour platform holds hundreds of commuters shoulder to shoulder",  "category": "CONTEXT",  "visual_relevance": "HIGH",   "confidence": 0.94, "visual_hint": "dense crowd under fluorescent light" },
        { "id": "F2", "text": "A pickpocket shadows a distracted commuter reading her phone",         "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.92, "visual_hint": "hooded figure drifting closer" },
        { "id": "F3", "text": "Two fingers lift a wallet from an open handbag as the train arrives", "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.95, "visual_hint": "hand sliding into handbag" },
        { "id": "F4", "text": "The thief melts into the boarding crowd before the doors close",      "category": "RESULT",   "visual_relevance": "MEDIUM", "confidence": 0.86, "visual_hint": "hood vanishing among passengers" }
    ],

    "world_objects": [
        { "id": "thief_obj",    "type": "character", "label": "Pickpocket",       "attributes": { "clothing": "grey hoodie" } },
        { "id": "victim_obj",   "type": "character", "label": "Commuter",         "attributes": { "clothing": "beige coat", "carrying": "open handbag" } },
        { "id": "platform_obj", "type": "location",  "label": "Subway platform",  "attributes": { "density": "rush hour" } }
    ],

    "world_facts": {
        "time": "evening rush hour",
        "crowd": "hundreds, shoulder to shoulder",
        "light": "harsh fluorescent",
        "sound": "arriving train",
        "train_status": "arriving"
    },

    "characters": [
        {
            "id": "thief",
            "label": "Pickpocket",
            "world_object_ref": "thief_obj",
            "appearance": { "outfit": "grey hoodie, dark jeans", "build": "slight, unremarkable" }
        },
        {
            "id": "victim",
            "label": "Commuter",
            "world_object_ref": "victim_obj",
            "appearance": { "outfit": "beige coat, handbag on shoulder", "build": "average" }
        }
    ],

    "emotion_arc": {
        "thief": [
            { "at": "baseline",   "state": "neutral",       "intensity": "subtle" },
            { "at": "escalation", "state": "determination", "intensity": "moderate", "cause": "target within reach, train covering the noise" },
            { "at": "payoff",     "state": "neutral",       "intensity": "subtle",   "cause": "practiced calm while disappearing" }
        ],
        "victim": [
            { "at": "baseline",   "state": "neutral",       "intensity": "subtle" }
        ]
    },

    "shots": {
        "hook": {
            "importance": "required",
            "action": "A packed platform seen from above, one hooded figure drifting against the current of commuters",
            "camera": { "shot_type": "wide", "angle": "high", "movement": "static", "lens": "wide", "focus_node": "crowd_node" },
            "ending_frame": "The hooded figure stops directly behind a woman reading her phone"
        },
        "escalation": {
            "importance": "required",
            "action": "The thief edges closer through jostling bodies as the train thunders in",
            "camera": { "shot_type": "medium", "angle": "eye_level", "movement": "tracking", "lens": "telephoto", "focus_node": "thief_node" },
            "ending_frame": "His hand hovers an inch from the open handbag"
        },
        "reveal": {
            "importance": "required",
            "action": "Two fingers lift the wallet clear of the handbag while the victim scrolls her phone, oblivious",
            "camera": { "shot_type": "insert", "angle": "high", "movement": "static", "lens": "telephoto", "focus_node": "handbag_node" },
            "ending_frame": "The wallet slips inside the hoodie pocket"
        },
        "payoff": {
            "importance": "optional",
            "action": "The thief steps onto the train among the boarding crowd, indistinguishable as the doors slide shut",
            "camera": { "shot_type": "wide", "angle": "eye_level", "movement": "dolly", "lens": "normal", "focus_node": "thief_node" },
            "ending_frame": "The doors close on a wall of anonymous faces"
        }
    },

    "scene_nodes": {
        "hook": [
            { "id": "crowd_node",  "type": "background", "label": "Rush-hour crowd", "world_object_ref": "platform_obj" },
            { "id": "thief_node",  "type": "subject",    "label": "Pickpocket",      "world_object_ref": "thief_obj" }
        ],
        "escalation": [
            { "id": "thief_node",  "type": "subject",    "label": "Pickpocket",      "world_object_ref": "thief_obj" },
            { "id": "victim_node", "type": "subject",    "label": "Commuter",        "world_object_ref": "victim_obj" }
        ],
        "reveal": [
            { "id": "handbag_node", "type": "subject",   "label": "Open handbag",    "world_object_ref": "victim_obj" },
            { "id": "thief_node",   "type": "subject",   "label": "Pickpocket",      "world_object_ref": "thief_obj" }
        ],
        "payoff": [
            { "id": "thief_node",  "type": "subject",    "label": "Pickpocket",      "world_object_ref": "thief_obj" },
            { "id": "crowd_node",  "type": "background", "label": "Boarding crowd",  "world_object_ref": "platform_obj" }
        ]
    }
}
