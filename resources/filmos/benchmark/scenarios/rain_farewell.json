{
    "schema_version": 1,
    "id": "rain_farewell",
    "suite": "emotion",
    "level": "A",
    "difficulty": "medium",
    "duration_seconds": 10,

    "primary_learning_dimension": "emotion_hold",
    "secondary_learning_dimensions": ["beat_pacing", "weather"],
    "stress_dimensions": ["rain_on_faces", "restrained_performance", "two_subject_framing"],

    "goal": "The audience should feel the weight of words neither person can say, so that a single small gesture at the end lands harder than any embrace.",

    "facts": [
        { "id": "F1", "text": "Two people stand under one umbrella at a night bus stop in heavy rain", "category": "CONTEXT",  "visual_relevance": "HIGH",   "confidence": 0.95, "visual_hint": "shared umbrella in streetlight rain" },
        { "id": "F2", "text": "The bus arrives and its doors open, waiting",                           "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.93, "visual_hint": "lit bus doors in the downpour" },
        { "id": "F3", "text": "She steps out from under the umbrella into the rain",                   "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.94, "visual_hint": "rain hitting her shoulders as she leaves cover" },
        { "id": "F4", "text": "He presses the umbrella into her hand and walks into the rain himself", "category": "RESULT",   "visual_relevance": "HIGH",   "confidence": 0.90, "visual_hint": "umbrella changing hands at the bus door" }
    ],

    "world_objects": [
        { "id": "man_obj",   "type": "character", "label": "Man",           "attributes": { "holding": "umbrella" } },
        { "id": "woman_obj", "type": "character", "label": "Woman",         "attributes": { "carrying": "travel bag" } },
        { "id": "stop_obj",  "type": "location",  "label": "Night bus stop", "attributes": { "lighting": "sodium streetlight" } }
    ],

    "world_facts": {
        "time": "late night",
        "weather": "heavy steady rain",
        "light": "warm streetlight through rainfall",
        "sound": "rain on umbrella fabric",
        "bus_status": "doors open, waiting"
    },

    "characters": [
        {
            "id": "man",
            "label": "Man",
            "world_object_ref": "man_obj",
            "appearance": { "outfit": "dark wool coat", "build": "tall" }
        },
        {
            "id": "woman",
            "label": "Woman",
            "world_object_ref": "woman_obj",
            "appearance": { "outfit": "light trench coat, travel bag", "build": "slender" }
        }
    ],

    "emotion_arc": {
        "man": [
            { "at": "baseline",   "state": "sadness",       "intensity": "subtle" },
            { "at": "hook",       "state": "sadness",       "intensity": "moderate", "cause": "the bus is coming and nothing has been said" },
            { "at": "escalation", "state": "sadness",       "intensity": "intense",  "cause": "she steps out of the umbrella's cover" },
            { "at": "payoff",     "state": "determination", "intensity": "moderate", "cause": "choosing to give her the umbrella instead of words" }
        ],
        "woman": [
            { "at": "baseline",   "state": "sadness",  "intensity": "moderate" },
            { "at": "escalation", "state": "sadness",  "intensity": "intense", "cause": "leaving before she changes her mind" },
            { "at": "payoff",     "state": "surprise", "intensity": "moderate", "cause": "the umbrella pressed into her hand" }
        ]
    },

    "shots": {
        "hook": {
            "importance": "required",
            "action": "Two people share an umbrella in silence at a rain-hammered bus stop, standing close but not touching",
            "camera": { "shot_type": "two_shot", "angle": "eye_level", "movement": "static", "lens": "normal", "focus_node": "pair_node" },
            "ending_frame": "Headlights of the approaching bus bloom in the rain behind them"
        },
        "escalation": {
            "importance": "required",
            "action": "She steps out from under the umbrella into the downpour toward the open bus doors, and he does not follow",
            "camera": { "shot_type": "medium", "angle": "eye_level", "movement": "handheld", "lens": "telephoto", "focus_node": "woman_node" },
            "ending_frame": "She pauses at the bus door, rain soaking her shoulders, not turning around"
        },
        "payoff": {
            "importance": "required",
            "action": "He crosses the rain and presses the umbrella into her hand, then walks away bareheaded into the downpour",
            "camera": { "shot_type": "close_up", "angle": "eye_level", "movement": "static", "lens": "telephoto", "focus_node": "hands_node" },
            "ending_frame": "Her hand closes around the wet umbrella handle as the doors begin to shut"
        }
    },

    "scene_nodes": {
        "hook": [
            { "id": "pair_node",  "type": "subject",    "label": "Two under umbrella", "world_object_ref": "man_obj" },
