    "goal": "The audience should be able to smell the market — steam, smoke and neon stacked so dense that one small stall feels like the centre of the world.",

    "facts": [
        { "id": "F1", "text": "A narrow market alley glows with stacked neon signs after rain",       "category": "CONTEXT",  "visual_relevance": "HIGH",   "confidence": 0.95, "visual_hint": "neon reflected in wet pavement" },
        { "id": "F2", "text": "A noodle vendor works a flaming wok behind clouds of steam",           "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.94, "visual_hint": "wok flame flaring through steam" },
        { "id": "F3", "text": "Skewers char over coals, smoke curling up through hanging lanterns",   "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.92, "visual_hint": "grill smoke through red lanterns" },
        { "id": "F4", "text": "A finished bowl lands steaming on the counter for a waiting customer", "category": "RESULT",   "visual_relevance": "MEDIUM", "confidence": 0.89, "visual_hint": "steaming bowl under stall light" }
    ],

