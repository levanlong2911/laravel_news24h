{
    "schema_version": 1,
    "id": "boxer_final_round",
    "suite": "emotion",
    "level": "A",
    "difficulty": "hard",
    "duration_seconds": 10,

    "primary_learning_dimension": "beat_pacing",
    "secondary_learning_dimensions": ["emotion_hold", "camera_tracking"],
    "stress_dimensions": ["exhausted_body_language", "sweat_and_blood_detail", "arena_lighting", "impact_physics"],

    "goal": "The audience should feel a beaten body argue with an unbeaten will, and know before the bell which one wins.",

    "facts": [
        { "id": "F1", "text": "The boxer sags on his stool between rounds, one eye swelling shut",     "category": "CONTEXT",  "visual_relevance": "HIGH",   "confidence": 0.95, "visual_hint": "slumped fighter under corner lights" },
        { "id": "F2", "text": "The scorecards need a knockout — points are not enough",                "category": "CONTEXT",  "visual_relevance": "MEDIUM", "confidence": 0.90, "visual_hint": "cornerman shouting into his ear" },
        { "id": "F3", "text": "He rises at the bell and walks into the exchange instead of away",      "category": "EVIDENCE", "visual_relevance": "HIGH",   "confidence": 0.94, "visual_hint": "fighter pushing off the stool" },
        { "id": "F4", "text": "A final right hand lands as the crowd surges to its feet",              "category": "RESULT",   "visual_relevance": "HIGH",   "confidence": 0.92, "visual_hint": "sweat spraying off the impact" }
    ],

    "world_objects": [
        { "id": "boxer_obj",    "type": "character", "label": "Boxer",        "attributes": { "corner": "red", "condition": "exhausted" } },
        { "id": "opponent_obj", "type": "character", "label": "Opponent",     "attributes": { "corner": "blue" } },
        { "id": "arena_obj",    "type": "location",  "label": "Boxing arena", "attributes": { "lighting": "single hard ring light" } }
    ],

    "world_facts": {
        "round": "twelfth and final",
        "score_state": "behind on all cards",
        "light": "hard white ring light, black arena void",
        "crowd": "on its feet, roaring",
        "air": "haze of sweat and chalk"
    },

    "characters": [
        {
            "id": "boxer",
            "label": "Boxer",
            "world_object_ref": "boxer_obj",
            "appearance": { "outfit": "red trunks, taped gloves, swelling left eye", "build": "welterweight, spent" }
        },
        {
            "id": "opponent",
            "label": "Opponent",
            "world_object_ref": "opponent_obj",
            "appearance": { "outfit": "blue trunks", "build": "welterweight, fresher" }
        }
    ],

    "emotion_arc": {
        "boxer": [
            { "at": "baseline",   "state": "fear",          "intensity": "moderate" },
            { "at": "hook",       "state": "sadness",       "intensity": "moderate", "cause": "body failing with one round left" },
            { "at": "escalation", "state": "determination", "intensity": "moderate", "cause": "cornerman's words cutting through the fog" },
            { "at": "payoff",     "state": "determination", "intensity": "intense",  "cause": "nothing left to save it for" }
        ]
    },

    "shots": {
        "hook": {
            "importance": "required",
            "action": "The boxer sags on his corner stool, one eye swelling shut, chest heaving under the hard ring light",
            "camera": { "shot_type": "close_up", "angle": "high", "movement": "handheld", "lens": "telephoto", "focus_node": "boxer_node" },
            "ending_frame": "His good eye lifts toward the opposite corner"
        },
        "escalation": {
            "importance": "required",
            "action": "The bell rings and he pushes off the stool, walking flat-footed into the centre instead of circling away",
            "camera": { "shot_type": "medium", "angle": "eye_level", "movement": "tracking", "lens": "normal", "focus_node": "boxer_node" },
            "ending_frame": "The two fighters meet at ring centre, gloves already rising"
        },
        "payoff": {
            "importance": "required",
            "action": "He eats a jab to throw the right hand, sweat spraying off the impact as the crowd surges to its feet",
            "camera": { "shot_type": "close_up", "angle": "low", "movement": "handheld", "lens": "normal", "focus_node": "exchange_node" },
            "ending_frame": "The opponent's knee touches canvas as the final bell begins to sound"
        }
    },

    "scene_nodes": {
        "hook": [
            { "id": "boxer_node",    "type": "subject",    "label": "Boxer on stool",  "world_object_ref": "boxer_obj" },
            { "id": "ringlight_node", "type": "light",     "label": "Ring light",      "world_object_ref": "arena_obj" }
        ],
        "escalation": [
            { "id": "boxer_node",    "type": "subject",    "label": "Boxer",           "world_object_ref": "boxer_obj" },
            { "id": "opponent_node", "type": "subject",    "label": "Opponent",        "world_object_ref": "opponent_obj" }
        ],
        "payoff": [
            { "id": "exchange_node", "type": "subject",    "label": "Final exchange",  "world_object_ref": "boxer_obj" },
            { "id": "crowd_node",    "type": "background", "label": "Standing crowd",  "world_object_ref": "arena_obj" }
        ]
    }
}
